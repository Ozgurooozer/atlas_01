{
  "video": {
    "resolution": [
      1920,
      1080
    ],
    "fullscreen": false,
    "vsync": true,
    "target_fps": 60,
    "brightness": 1.0,
    "gamma": 1.0,
    "show_fps": false
  },
  "audio": {
    "master_volume": 1.0,
    "sfx_volume": 1.0,
    "music_volume": 0.8,
    "voice_volume": 1.0,
    "mute_on_focus_loss": false
  },
  "input": {
    "mouse_sensitivity": 1.0,
    "invert_y": false,
    "invert_x": false,
    "key_bindings": {
      "move_up": "w",
      "move_down": "s",
      "move_left": "a",
      "move_right": "d",
      "jump": "space",
      "attack": "mouse_left",
      "dodge": "shift",
      "interact": "e",
      "menu": "escape"
    }
  }
}